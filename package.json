{
  "name": "@liontree/opencode-agent-sdk",
  "version": "0.1.1",
  "description": "High-level agent runtime built on top of @opencode-ai/sdk",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
