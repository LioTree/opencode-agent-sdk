  },
  "keywords": [
    "opencode",
    "agent",
    "sdk"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LioTree/opencode-agent-sdk.git"
  },
  "homepage": "https://github.com/LioTree/opencode-agent-sdk#readme",
